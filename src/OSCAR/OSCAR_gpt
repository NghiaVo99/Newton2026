def plot_metric_vs_iter(df, metric, ylabel, title, fname):
    plt.figure()
    for method in df["method"].unique():
        sub = df[df["method"] == method]
        plt.plot(sub["iter"].values, sub[metric].values, label=method)
    plt.yscale("log")
    plt.xlabel("Iteration")
    plt.ylabel(ylabel)
    plt.title(title)
    plt.legend()
    plt.tight_layout()
    #plt.savefig(fname)
    plt.show()

def plot_metric_vs_time(df, metric, ylabel, title, fname):
    plt.figure()
    for method in df["method"].unique():
        sub = df[df["method"] == method]
        plt.plot(sub["time_sec"].values, sub[metric].values, label=method)
    plt.yscale("log")
    plt.xlabel("Time (s)")
    plt.ylabel(ylabel)
    plt.title(title)
    plt.legend()
    plt.tight_layout()
    #plt.savefig(fname)
    plt.show()

plot_metric_vs_iter(df_all, "f_gap", r"$f_k - f^\star$", "Objective gap vs Iteration", "/mnt/data/obj_gap_vs_iter_small.png")
plot_metric_vs_time(df_all, "f_gap", r"$f_k - f^\star$", "Objective gap vs Time", "/mnt/data/obj_gap_vs_time_small.png")
plot_metric_vs_iter(df_all, "x_err", r"$\|x_k - x^\star\|_2$", "Iterate error vs Iteration", "/mnt/data/xerr_vs_iter_small.png")
plot_metric_vs_time(df_all, "x_err", r"$\|x_k - x^\star\|_2$", "Iterate error vs Time", "/mnt/data/xerr_vs_time_small.png")

